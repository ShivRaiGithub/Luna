PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRY=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password

# OTP
OTP_EXPIRY_MINUTES=10

# CORS
CORS_ORIGIN=http://localhost:3000

# Midnight RPC endpoints (optional overrides)
MIDNIGHT_RPC_MAINNET=https://rpc.mainnet.midnight.network
MIDNIGHT_RPC_PREPROD=https://rpc.preprod.midnight.network
MIDNIGHT_RPC_PREVIEW=https://rpc.preview.midnight.network
MIDNIGHT_RPC_UNDEPLOYED=http://localhost:9944
# Legacy alias still supported
MIDNIGHT_RPC_LOCALNET=http://localhost:9944

# MongoDB
MONGODB_URI=mongodb://localhost:27017/luna
